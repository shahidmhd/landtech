# Public site URL — used for OG/SEO metadata + sitemap
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Brand
NEXT_PUBLIC_BRAND_NAME=Landtech Real Estate
NEXT_PUBLIC_BRAND_PHONE=+971-000-000-000
NEXT_PUBLIC_BRAND_EMAIL=hello@landtech.example

# Lead form delivery — POSTed as JSON when set; falls back to thank-you state when empty.
# Examples once chosen:
#   Formspree:        NEXT_PUBLIC_LEADS_ENDPOINT=https://formspree.io/f/yourcode
#   Future backend:   NEXT_PUBLIC_LEADS_ENDPOINT=https://api.landtech.example/api/leads
NEXT_PUBLIC_LEADS_ENDPOINT=

# Optional Google Maps JS API key. If empty, MapView falls back to a static "View on Google Maps" link.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
